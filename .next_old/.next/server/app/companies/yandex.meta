{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/companies/layout,_N_T_/companies/[slug]/layout,_N_T_/companies/[slug]/page,_N_T_/companies/yandex"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/companies/$d$slug/__PAGE__",
    "/companies/$d$slug",
    "/companies",
    "/_index",
    "/_head"
  ]
}